@model FinMind.Web.Models.FetchRequestViewModel
@{
    ViewData["Title"] = "FinMind K-Bar Fetch";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="mb-3">FinMind K-Bar Fetch UI</h1>
        <p class="text-muted">Input symbol, start date, and end date to run <code>app.py</code>.</p>
        <div class="mb-3">
            <a asp-action="DownloadLatestCsv" class="btn btn-outline-secondary">Download Latest Generated CSV</a>
        </div>

        <form asp-action="Index" method="post" class="card p-4 shadow-sm">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Symbol" class="form-label"></label>
                <input asp-for="Symbol" class="form-control" placeholder="e.g. 2330" />
                <span asp-validation-for="Symbol" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Run Python</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.OutputMessage))
        {
            <div class="alert alert-success mt-3">@Model.OutputMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.CommandOutput))
        {
            <div class="card mt-3">
                <div class="card-header">Python Output</div>
                <div class="card-body">
                    <pre class="mb-0">@Model.CommandOutput</pre>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
